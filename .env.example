# Cloudflare API Token for Let's Encrypt DNS-01 Challenge
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token_here

# Email address for Let's Encrypt registration and recovery
ACME_EMAIL=admin@your-domain.local

# Public DNS for Let's Encrypt / Split-Brain workaround (1.1.1.1 and 1.0.0.1 are set as fallback)
PUBLIC_DNS_1=set_public_dns_here
PUBLIC_DNS_2=set_public_dns_here
