{
    email {$ACME_EMAIL}
}

# The Wildcard Configuration
*.int.sdr.wtf {
    tls {
        dns cloudflare {$CLOUDFLARE_API_TOKEN}
        resolvers 1.1.1.1:53 1.0.0.1:53
        propagation_delay 60s
    }

    # 1. Route for Technitium DNS Dashboard
    @dns host dns.int.sdr.wtf
    handle @dns {
        reverse_proxy 10.0.30.20:5380
    }

    # 2. Route for Proxmox VE
    @pve host pve.int.sdr.wtf
    handle @pve {
        reverse_proxy 10.0.0.10:8006 {
            transport http {
                tls_insecure_skip_verify
            }
        }
    }

    # 3. Route for Proxmox MG
    @pmg host pmg.int.sdr.wtf
    handle @pmg {
        reverse_proxy 10.0.0.12:8006 {
            transport http {
                tls_insecure_skip_verify
            }
        }
    }

    # 4. Route for Ansible Semaphore
    @semaphore host semaphore.int.sdr.wtf
    handle @semaphore {
        reverse_proxy 10.0.30.20:3000
    }

    # 5. Route for Proxmox Backup Server (Hetzner via WireGuard)
    @pbs host pbs.int.sdr.wtf
    handle @pbs {
        reverse_proxy https://192.168.7.2:8007 {
            transport http {
                tls_insecure_skip_verify
            }
        }
    }

    # 6. Route for Checkmk Monitoring
    @checkmk host checkmk.int.sdr.wtf
    handle @checkmk {
        reverse_proxy 10.0.30.20:8080
    }

    # Fallback / Default for anything else
    handle {
        respond "Service not found or not yet configured in Caddy." 404
    }
}
